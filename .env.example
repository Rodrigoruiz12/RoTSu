# =============================================================================
# .env.example - Variables de entorno para desarrollo local y CI/CD
# -----------------------------------------------------------------------------
# Copiar a .env (no commitear) y ajustar valores. En CI/CD estas variables
# se configuran como GitHub Secrets o en terraform.tfvars.
# =============================================================================

# --- AWS (para terraform apply local) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- SonarCloud ---
# Obtener en: https://sonarcloud.io/account/security
SONAR_TOKEN=
SONAR_ORGANIZATION=rotsu
SONAR_PROJECT_KEY=rotsu_frontend

# --- Snyk ---
# Obtener en: https://app.snyk.io/account
SNYK_TOKEN=

# --- Terraform / Kubernetes ---
# (kubeadm genera su propio join token en runtime, no requiere variable)

# --- SSH para acceder a la EC2 (OPCIONAL) ---
# Por defecto el proyecto usa AWS SSM Session Manager (no requiere SSH).
# Solo configurar si necesitas acceso SSH de debug.
# Contenido de: cat ~/.ssh/id_ed25519.pub
# SSH_PUBLIC_KEY=
# ENABLE_SSH_ACCESS=false

# --- Pushgateway (solo CI) ---
# Tras primer terraform apply, queda en http://<EC2_IP>:9091
PUSHGATEWAY_URL=http://localhost:9091

# --- App ---
NODE_ENV=development
VITE_API_URL=http://localhost:3000
