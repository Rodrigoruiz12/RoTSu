{
  "comment": "Configuración de branch protection aplicada vía gh api (IE5/IE6). Ejecutar: bash scripts/apply-branch-protection.sh",
  "required_status_checks": {
    "strict": true,
    "contexts": [
      "build-and-test",
      "sonarcloud",
      "snyk-security",
      "audit-compliance"
    ]
  },
  "enforce_admins": true,
  "required_pull_request_reviews": {
    "dismiss_stale_reviews": true,
    "require_code_owner_reviews": false,
    "required_approving_review_count": 1
  },
  "restrictions": null,
  "required_linear_history": true,
  "allow_force_pushes": false,
  "allow_deletions": false
}
